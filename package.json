{
  "name": "untouched",
  "version": "0.1.0",
  "description": "get pristine copies of built-in objects (like Array or JSON) even if they've been modified",
  "main": "untouched.js",
  "type": "module",
  "scripts": {
    "pretest": "npm run lint",
    "lint": "npm run lint:prettier && npm run lint:eslint",
    "lint:prettier": "prettier --check .",
    "lint:eslint": "eslint .",
    "format": "prettier --write .",
    "test": "node --test test/index.js"
  },
  "keywords": [
    "untouched",
    "pristine",
    "original",
    "native"
  ],
  "author": "Evan Hahn <me@evanhahn.com> (https://evanhahn.com)",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/EvanHahn/untouched.git"
  },
  "bugs": "https://codeberg.org/EvanHahn/untouched/issues",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "puppeteer": "^25.2.1",
    "serve-static": "^2.2.1"
  },
  "allowScripts": {
    "puppeteer@25.2.1": true
  }
}
